NODE_ENV=development
PORT=3000

# 远程 PostgreSQL 连接（Prisma Postgres / Vercel Postgres 等）
# 应用与 Prisma CLI 优先读取 POSTGRES_URL
POSTGRES_URL="postgres://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require"
DATABASE_URL="postgres://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require"
PRISMA_DATABASE_URL="postgres://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require"

# Vercel 部署时在控制台 Environment Variables 中配置（Storage 创建 Postgres 后会自动注入）：
# POSTGRES_URL / POSTGRES_PRISMA_URL / POSTGRES_URL_NON_POOLING
# ENCRYPTION_KEY / HMAC_SECRET / REQUEST_SECRET

# 本地 PostgreSQL（可选，仅在不使用远程库时配置）
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=crud_api
# DB_USER=postgres
# DB_PASSWORD=your_password_here

# 加密配置
ENCRYPTION_KEY=your-encryption-key-change-in-production
HMAC_SECRET=your-hmac-secret-change-in-production
REQUEST_SECRET=your-request-secret-change-in-production

# CORS配置
CORS_ORIGIN=*
ALLOWED_ORIGIN=http://localhost:3000
