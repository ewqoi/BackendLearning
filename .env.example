NODE_ENV=development
PORT=3000

# 数据库配置（本地开发）
DB_HOST=localhost
DB_PORT=5432
DB_NAME=crud_api
DB_USER=postgres
DB_PASSWORD=your_password_here

# Vercel PostgreSQL 环境变量（部署时自动配置）
# POSTGRES_URL=
# POSTGRES_URL_NON_POOLING=
# POSTGRES_PRISMA_URL=
# POSTGRES_USER=
# POSTGRES_HOST=
# POSTGRES_PASSWORD=
# POSTGRES_DATABASE=

# 加密配置
ENCRYPTION_KEY=your-encryption-key-change-in-production
HMAC_SECRET=your-hmac-secret-change-in-production
REQUEST_SECRET=your-request-secret-change-in-production

# CORS配置
CORS_ORIGIN=*
ALLOWED_ORIGIN=http://localhost:3000
